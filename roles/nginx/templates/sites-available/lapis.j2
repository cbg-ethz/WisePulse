server {
    server_name lapis.{{ nginx_domain_name }};

    # Redirect /covid without trailing slash
    location = /covid {
        return 301 /covid/;
    }

    # COVID instance - proxy with path stripped via trailing slash
    location /covid/ {
        proxy_pass http://lapis-covid/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix /covid/;
    }

    # Redirect /rsva without trailing slash
    location = /rsva {
        return 301 /rsva/;
    }

    # RSVA instance - proxy with path stripped via trailing slash
    location /rsva/ {
        proxy_pass http://lapis-rsva/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix /rsva/;
    }

    # Backward compatibility: proxy all other requests to COVID backend
    # This catches /, /sample/info, etc. and proxies directly (no redirect)
    # Using proxy instead of redirect to preserve CORS preflight behavior
    location / {
        proxy_pass http://lapis-covid;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    listen 443 ssl http2; # managed by Certbot
    ssl_certificate {{ nginx_lapis_ssl_certificate_path }}; # managed by Certbot
    ssl_certificate_key {{ nginx_lapis_ssl_certificate_key_path }}; # managed by Certbot
    include /etc/nginx/snippets/ssl-params.conf;
}

server {
    if ($host = lapis.{{ nginx_domain_name }}) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    server_name lapis.{{ nginx_domain_name }};
    return 404; # managed by Certbot
}
