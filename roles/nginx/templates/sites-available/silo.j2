server {
    server_name silo.{{ nginx_domain_name }};

    # COVID instance - strip /covid prefix and proxy to backend
    location /covid {
        rewrite ^/covid(.*)$ $1 break;
        proxy_pass http://127.0.0.1:{{ nginx_silo_covid_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # RSVA instance - strip /rsva prefix and proxy to backend
    location /rsva {
        rewrite ^/rsva(.*)$ $1 break;
        proxy_pass http://127.0.0.1:{{ nginx_silo_rsva_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Backward compatibility: proxy all other requests to COVID backend
    # This catches /, /info, etc. and proxies directly (no redirect)
    # Using proxy instead of redirect to preserve CORS preflight behavior
    location / {
        proxy_pass http://127.0.0.1:{{ nginx_silo_covid_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    listen 443 ssl http2; # managed by Certbot
    ssl_certificate {{ nginx_silo_ssl_certificate_path }}; # managed by Certbot
    ssl_certificate_key {{ nginx_silo_ssl_certificate_key_path }}; # managed by Certbot
    include /etc/nginx/snippets/ssl-params.conf;
}

server {
    if ($host = silo.{{ nginx_domain_name }}) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    server_name silo.{{ nginx_domain_name }};
    return 404; # managed by Certbot
}
